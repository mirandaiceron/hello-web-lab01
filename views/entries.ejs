<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="/style.css">
</head>

<body>

  <input type="checkbox" id="theme-toggle" class="theme-toggle">
  <label for="theme-toggle">Dark mode</label>

  <%- include("partials/header") %>

  <main>
    <h2><%= title %></h2>

    <ul>
      <% entries.forEach(entry => { %>
        <li><%= entry.title %></li>
      <% }) %>
    </ul>
  </main>

</body>
</html>